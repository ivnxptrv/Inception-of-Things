K3S_TOKEN = "ipetrovS42iotjoinsecret"   # any random string; same on both VMs

Vagrant.configure(2) do |config|
    # config.vm.box = "cloud-image/alpine-3.23" 
    # config.vm.box = "generic/ubuntu2204" 
    # config.vm.box = "generic/alpine318"
    config.vm.box = "generic/debian12"
    config.vm.provision "shell", inline: <<-SHELL
        # [..] Shell script content here
    SHELL
    # config.vm.synced_folder ".", "/vagrant", type: "rsync"
    
    config.vm.provider :libvirt do |v|
        v.default_prefix = "" # Prevents Vagrant from adding a folder prefix
        v.random_hostname = false

        v.memory = 2048  # Sets RAM in MB
        v.cpus = 2      # Sets number of CPU cores

        # v.memory = 512  # Sets RAM in MB
        # v.cpus = 1      # Sets number of CPU cores
    end

    # config.vm.network :private_network
    
    # Define ipetrovS machine / Server
    config.vm.define "ipetrovS" do |control|
        control.vm.hostname = "ipetrovS"
        control.vm.network :private_network, ip: "192.168.56.110", libvirt__dhcp_enabled: false
        control.vm.provision "shell", inline: <<-SHELL
            export DEBIAN_FRONTEND=noninteractive
            apt-get update -qq
            apt-get install -y -qq curl iproute2
            curl -sfL https://get.k3s.io | \
                INSTALL_K3S_VERSION=v1.30.5+k3s1 \
                K3S_TOKEN="#{K3S_TOKEN}" \
                INSTALL_K3S_EXEC="server \
                    --node-ip=192.168.56.110 \
                    --bind-address=192.168.56.110 \
                    --advertise-address=192.168.56.110 \
                    --flannel-iface=eth1" \
                sh -

            # Wait until the API is actually serving, so kubectl works post-up
            for i in $(seq 1 60); do
                kubectl get nodes >/dev/null 2>&1 && break
                sleep 2
            done
        SHELL
                           
        # control.vm.provision "shell", path: REDACTED
    end

    # Define ipetrovW machine / ServerWorker
    config.vm.define "ipetrovSW" do |control|
        control.vm.hostname = "ipetrovSW"
        control.vm.network :private_network, ip: "192.168.56.111", libvirt__dhcp_enabled: false
        control.vm.provision "shell", inline: <<-SHELL
                    export DEBIAN_FRONTEND=noninteractive
                    apt-get update -qq
                    apt-get install -y -qq curl iproute2
                    curl -sfL https://get.k3s.io | \
                        INSTALL_K3S_VERSION=v1.30.5+k3s1 \
                        K3S_URL="https://192.168.56.110:6443" \
                        K3S_TOKEN="#{K3S_TOKEN}" \
                        INSTALL_K3S_EXEC="agent \
                            --node-ip=192.168.56.111 \
                            --flannel-iface=eth1" \
                        sh -
                SHELL
        # control.vm.provision "shell", path: REDACTED
    end
end
